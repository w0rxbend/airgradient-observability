# Public DNS name for the OCI Caddy endpoint.
# Must be a real hostname for Caddy automatic HTTPS.
DOMAIN=metrics.example.com

# Caddy Basic Auth username.
# Must match VM_USER in ../edge/vm-agent-airgradient/.env.
BASIC_AUTH_USER=vmwriter

# Caddy Basic Auth bcrypt hash.
# Generate this from the same plaintext password used as edge VM_PASSWORD:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'CHANGE_ME'
BASIC_AUTH_HASH='$2a$14$replace-with-caddy-bcrypt-hash'

# Production images for app services.
# Use registry references in production, for example:
# ghcr.io/YOUR_ORG/airgradient-backend:2026-05-29
# ghcr.io/YOUR_ORG/airgradient-frontend:2026-05-29
BACKEND_IMAGE=ghcr.io/YOUR_ORG/airgradient-backend:latest
FRONTEND_IMAGE=ghcr.io/YOUR_ORG/airgradient-frontend:latest

# Frontend backend proxy configuration.
# Leave BACKEND_URL empty to use frontend.config.json.
BACKEND_URL=
FRONTEND_CONFIG_FILE=/app/config.json

# Public OCI Caddy endpoint.
# Must match DOMAIN in ../../oci/.env.
DOMAIN=metrics.example.com

# Basic Auth username for VictoriaMetrics remote write through Caddy.
# Must match BASIC_AUTH_USER in ../../oci/.env.
VM_USER=vmwriter

# Plaintext password for VictoriaMetrics remote write through Caddy.
# OCI BASIC_AUTH_HASH must be generated from this same plaintext password.
VM_PASSWORD=CHANGE_ME
